<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuración de seguridad de red — PRODUCCIÓN
  - Bloquea todo tráfico HTTP en claro (solo HTTPS permitido).
  - No se declaran dominios con cleartext permitido.
  - Firebase / FCM ya usan HTTPS — no requieren excepciones.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
